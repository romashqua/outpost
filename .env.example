# Outpost VPN — Environment Variables
# Copy to .env and adjust values for your environment.
# For development: cp .env.example .env

# ─── Database ───────────────────────────────────────────────
POSTGRES_PASSWORD=outpost-dev-password
DATABASE_URL=postgres://outpost:outpost-dev-password@localhost:5432/outpost?sslmode=disable

# ─── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=outpost-dev-password

# ─── Auth ───────────────────────────────────────────────────
# CHANGE THIS IN PRODUCTION! Generate with: openssl rand -hex 32
JWT_SECRET=outpost-dev-jwt-secret-change-me

# ─── Gateway ────────────────────────────────────────────────
# Token for gateway <-> core authentication
GATEWAY_TOKEN=outpost-dev-gateway-token

# ─── Server ─────────────────────────────────────────────────
OUTPOST_HTTP_ADDR=:8080
OUTPOST_GRPC_ADDR=:9090

# ─── OIDC Provider ──────────────────────────────────────────
OUTPOST_OIDC_ISSUER=http://localhost:8080

# ─── LDAP (optional) ────────────────────────────────────────
OUTPOST_LDAP_ENABLED=false
# OUTPOST_LDAP_URL=ldap://ldap.example.com:389
# OUTPOST_LDAP_BIND_DN=cn=admin,dc=example,dc=com
# OUTPOST_LDAP_BIND_PASSWORD=
# OUTPOST_LDAP_BASE_DN=dc=example,dc=com

# ─── SAML (optional) ────────────────────────────────────────
OUTPOST_SAML_ENABLED=false
# OUTPOST_SAML_ENTITY_ID=https://outpost.example.com
# OUTPOST_SAML_ACS_URL=https://outpost.example.com/saml/acs
# OUTPOST_SAML_IDP_METADATA_URL=

# ─── Email (optional) ───────────────────────────────────────
# OUTPOST_SMTP_HOST=smtp.example.com
# OUTPOST_SMTP_PORT=587
# OUTPOST_SMTP_USER=
# OUTPOST_SMTP_PASSWORD=
# OUTPOST_SMTP_FROM=noreply@example.com

# ─── Logging ────────────────────────────────────────────────
OUTPOST_LOG_LEVEL=debug
OUTPOST_LOG_FORMAT=text

# ─── Client ─────────────────────────────────────────────────
OUTPOST_SERVER=http://localhost:8080
